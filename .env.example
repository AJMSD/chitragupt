# Ops agent port (agent service). Host is fixed to 127.0.0.1 by design.
AGENT_PORT=7777

# Base URL used by Next.js API routes to reach the local agent.
AGENT_URL=http://127.0.0.1:7777

# Optional disk type overrides (comma-separated). Accepts mount or device.
# Examples:
# DISK_TYPE_OVERRIDE=/=hdd,/mnt/Extreme500=ssd,/dev/sdc1=ssd
DISK_TYPE_OVERRIDE=

# Single-user auth for the private area.
# AUTH_PASSWORD should be a strong passphrase.
AUTH_PASSWORD=

# AUTH_SECRET signs session cookies (use a long random string).
AUTH_SECRET=

# Optional session lifetime in seconds (default: 604800).
AUTH_SESSION_MAX_AGE_SECONDS=604800
