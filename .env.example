# Ops agent port (agent service). Host is fixed to 127.0.0.1 by design.
AGENT_PORT=7777

# Base URL used by Next.js API routes to reach the local agent.
AGENT_URL=http://127.0.0.1:7777

# Shared token required for private agent endpoints (send as header).
AGENT_TOKEN=

# Optional overrides for the agent auth headers.
AGENT_TOKEN_HEADER=x-agent-token
AGENT_PRIVATE_HEADER=x-ajmsd-private
AGENT_PRIVATE_VALUE=1

# Optional disk type overrides (comma-separated). Accepts mount or device.
# Examples:
# DISK_TYPE_OVERRIDE=/=hdd,/mnt/Extreme500=ssd,/dev/sdc1=ssd
DISK_TYPE_OVERRIDE=

# Allowlisted roots for the file browser (JSON array).
# Update these paths and IDs to match your environment.
ALLOWLIST_ROOTS=[{"id":"code","label":"Code","path":"/home/ajmsd/Code"},{"id":"backup","label":"Backup","path":"/home/ajmsd/Backup"},{"id":"gdrive","label":"GDrive","path":"/home/ajmsd/GDrive"},{"id":"mnt","label":"mnt","path":"/mnt"}]

# Log sources (JSON array). Each entry must include id, label, type, and target.
# type: "docker" | "systemd" | "file"
LOG_SOURCES=[{"id":"immich","label":"Immich","type":"docker","target":"immich"},{"id":"jellyfin","label":"Jellyfin","type":"systemd","target":"jellyfin.service"},{"id":"minecraft","label":"Minecraft","type":"file","target":"/var/log/minecraft.log"},{"id":"terraria","label":"Terraria","type":"file","target":"/var/log/terraria.log"}]

# Log tail defaults.
LOG_DEFAULT_LINES=200
LOG_MAX_LINES=500

# Single-user auth for the private area.
# AUTH_PASSWORD should be a strong passphrase.
AUTH_PASSWORD=

# AUTH_SECRET signs session cookies (use a long random string).
AUTH_SECRET=

# Optional session lifetime in seconds (default: 604800).
AUTH_SESSION_MAX_AGE_SECONDS=604800
