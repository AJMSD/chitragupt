{
    "name": "chitragupt",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "concurrently -k -n web,agent \"next dev\" \"tsx watch -r dotenv/config agent/src/server.ts\"",
        "dev:webpack": "concurrently -k -n web,agent \"next dev --no-turbo\" \"tsx watch -r dotenv/config agent/src/server.ts\"",
        "dev:web": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "test:terminal": "tsx --test agent/src/terminal-session-accounting.test.ts agent/src/terminal-fallback.test.ts app/app/terminal/lifecycle.test.ts app/app/terminal/errors.test.ts app/app/terminal/command-format.test.ts",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "agent:build": "tsc -p agent/tsconfig.json",
        "agent:dev": "tsx watch -r dotenv/config agent/src/server.ts",
        "agent:start": "node -r dotenv/config agent/dist/server.js"
    },
    "dependencies": {
        "@tailwindcss/postcss": "^4",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "hack-font": "^3.3.0",
        "next": "16.1.5",
        "node-pty": "^1.1.0",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "tailwindcss": "^4",
        "yazl": "^3.3.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/yazl": "^3.3.1",
        "concurrently": "^8.2.2",
        "dotenv": "^16.4.5",
        "eslint": "^9",
        "eslint-config-next": "16.1.5",
        "tsx": "^4.19.2",
        "typescript": "^5"
    }
}
